<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/space_black">

    <!-- Animated starfield background -->
    <com.example.portedesetoiles.StarfieldView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Central content: title + stargate + status — centered vertically -->
    <LinearLayout
        android:id="@+id/contentArea"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/serviceSwitch"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- App title -->
        <TextView
            android:id="@+id/appTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@string/app_name"
            android:textColor="@color/gate_teal_dim"
            android:textSize="13sp"
            android:letterSpacing="0.25"
            android:fontFamily="monospace"
            android:gravity="center"/>

        <!-- Stargate view (square, auto-sized to width) -->
        <com.example.portedesetoiles.StargateView
            android:id="@+id/stargateView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="28dp"/>

        <!-- Status card: indicator + distance -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/statusCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="28dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/status_bg"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:paddingVertical="14dp"
                android:gravity="center_vertical">

                <!-- Left: dot + state label -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <View
                            android:id="@+id/indicatorDot"
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/dot_indicator"/>

                        <TextView
                            android:id="@+id/stateText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/state_at_home"
                            android:textColor="@color/gate_text_dim"
                            android:textSize="11sp"
                            android:letterSpacing="0.12"
                            android:fontFamily="monospace"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/statusText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/status_idle"
                        android:textColor="#3A4A5A"
                        android:textSize="10sp"
                        android:fontFamily="monospace"/>
                </LinearLayout>

                <!-- Right: distance -->
                <TextView
                    android:id="@+id/distanceText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/gate_teal"
                    android:textSize="28sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- Service toggle -->
    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/serviceSwitch"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="28dp"
        android:layout_marginBottom="4dp"
        android:text="@string/service_label"
        android:textColor="@color/gate_text_dim"
        android:textSize="13sp"
        android:fontFamily="monospace"
        app:layout_constraintBottom_toTopOf="@id/settingsButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Settings button — bottom center -->
    <ImageButton
        android:id="@+id/settingsButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginBottom="12dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_preferences"
        android:tint="@color/gate_text_dim"
        android:contentDescription="@string/settings"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
